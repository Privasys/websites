{
    "name": "explorer.privasys.org",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/fronts/explorer.privasys.org",
    "projectType": "application",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "outputs": ["{workspaceRoot}/dist/apps/fronts/explorer.privasys.org"],
            "options": {
                "commands": [
                    "node apps/fronts/explorer.privasys.org/scripts/copy-static.cjs apps/fronts/explorer.privasys.org dist/apps/fronts/explorer.privasys.org"
                ]
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx serve -l 4210 -s .",
                "cwd": "apps/fronts/explorer.privasys.org",
                "port": 4210
            }
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "echo 'Static HTML — no lint configured'"
            }
        },
        "e2e": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx playwright test --config apps/fronts/explorer.privasys.org/e2e/playwright.config.ts"
            }
        }
    }
}
