{
    "name": "explorer.privasys.org",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/fronts/explorer.privasys.org",
    "projectType": "application",
    "tags": [],
    "targets": {
        "build": {
            "executor": "@nx/next:build",
            "outputs": [
                "{options.outputPath}"
            ],
            "defaultConfiguration": "production",
            "options": {
                "outputPath": "dist/apps/fronts/explorer.privasys.org"
            },
            "configurations": {
                "development": {
                    "outputPath": "apps/fronts/explorer.privasys.org"
                },
                "production": {}
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx next dev -p 4218",
                "cwd": "apps/fronts/explorer.privasys.org"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": [
                "{options.outputFile}"
            ]
        },
        "e2e": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx playwright test --config apps/fronts/explorer.privasys.org/e2e/playwright.config.ts"
            }
        }
    }
}
