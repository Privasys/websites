# ─── Auth.js (next-auth v5) ─────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Zitadel OIDC — create a "Web" application in Zitadel, then fill these in.
# Redirect URIs to register in Zitadel:
#   http://localhost:4210/api/auth/callback/zitadel   (dev)
#   https://developer-test.privasys.org/api/auth/callback/zitadel  (test)
#   https://developer.privasys.org/api/auth/callback/zitadel  (prod)
AUTH_ZITADEL_ISSUER=https://auth.privasys.org
AUTH_ZITADEL_ID=
AUTH_ZITADEL_SECRET=

# Required in production; "true" tells Auth.js to trust the X-Forwarded-Host header
AUTH_TRUST_HOST=true

# ─── Management Service API ────────────────────────────────────
# URL reachable **from the browser** (CORS on the management service must allow
# the portal origin that pairs with this URL).
#
# ⚠️  NEXT_PUBLIC_* variables are BAKED AT BUILD TIME by Next.js.
# Changing them at Docker runtime has NO effect on client-side code.
# You must rebuild the portal for each target environment.
#
# Local development:
NEXT_PUBLIC_API_URL=http://localhost:8080
#
# Test build:   NEXT_PUBLIC_API_URL=https://api-test.developer.privasys.org
# Prod build:   NEXT_PUBLIC_API_URL=https://api.developer.privasys.org
