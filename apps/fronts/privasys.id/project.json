{
    "name": "privasys.id",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/fronts/privasys.id",
    "projectType": "application",
    "targets": {
        "build": {
            "executor": "nx:run-commands",
            "outputs": ["{workspaceRoot}/dist/apps/fronts/privasys.id"],
            "options": {
                "commands": [
                    "node apps/fronts/privasys.id/scripts/copy-static.cjs apps/fronts/privasys.id dist/apps/fronts/privasys.id"
                ]
            }
        },
        "serve": {
            "executor": "nx:run-commands",
            "options": {
                "command": "npx serve -l 54282 -s .",
                "cwd": "apps/fronts/privasys.id"
            }
        },
        "lint": {
            "executor": "nx:run-commands",
            "options": {
                "command": "echo 'Static HTML — no lint configured'"
            }
        }
    }
}
