{
    "name": "privasys.org",
    "$schema": "../../../node_modules/nx/schemas/project-schema.json",
    "sourceRoot": "apps/fronts/privasys.org",
    "projectType": "application",
    "tags": [],
    "targets": {
        "copy-logo": {
            "executor": "nx:run-commands",
            "inputs": ["{workspaceRoot}/assets/logo/**"],
            "outputs": ["{projectRoot}/public/favicon"],
            "options": {
                "command": "node -e \"require('fs').cpSync('assets/logo','apps/fronts/privasys.org/public/favicon',{recursive:true,force:true})\""
            }
        },
        "copy-fonts": {
            "executor": "nx:run-commands",
            "inputs": ["{workspaceRoot}/assets/fonts/**"],
            "outputs": ["{projectRoot}/public/fonts"],
            "options": {
                "command": "node -e \"require('fs').cpSync('assets/fonts','apps/fronts/privasys.org/public/fonts',{recursive:true,force:true})\""
            }
        },
        "build": {
            "dependsOn": ["copy-logo", "copy-fonts"],
            "executor": "@nx/next:build",
            "outputs": [
                "{options.outputPath}"
            ],
            "defaultConfiguration": "production",
            "options": {
                "outputPath": "dist/apps/fronts/privasys.org"
            },
            "configurations": {
                "development": {
                    "outputPath": "apps/fronts/privasys.org"
                },
                "production": {}
            }
        },
        "postbuild": {
            "dependsOn": [
                "build"
            ],
            "executor": "nx:run-commands",
            "options": {
                "command": "yarn next-sitemap --config next-sitemap.config.cjs",
                "cwd": "apps/fronts/privasys.org"
            }
        },
        "serve": {
            "dependsOn": ["copy-logo", "copy-fonts"],
            "executor": "nx:run-commands",
            "options": {
                "command": "npx next dev -p 4208",
                "cwd": "apps/fronts/privasys.org"
            }
        },
        "test": {
            "executor": "@nx/jest:jest",
            "outputs": [
                "{workspaceRoot}/coverage/{projectRoot}"
            ],
            "options": {
                "jestConfig": "apps/fronts/privasys.org/jest.config.ts"
            }
        },
        "lint": {
            "executor": "@nx/eslint:lint",
            "outputs": [
                "{options.outputFile}"
            ]
        },
        "dockerize": {
            "executor": "nx:run-commands",
            "options": {
                "command": "docker build --platform linux/amd64 -t privasys/privasys.org:latest -f apps/fronts/privasys.org/Dockerfile dist/apps/fronts/privasys.org"
            },
            "dependsOn": [
                "postbuild"
            ]
        }
    }
}